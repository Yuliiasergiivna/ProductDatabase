@using ProductLibrary.ASPMVC.Models.Product
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model IEnumerable<ListItemViewModel>

@{
    ViewData["Title"] = "Liste des produits";
    // Проверяем, залогинен ли пользователь
    var userId = HttpContextAccessor.HttpContext?.Session.GetString("UserId");
    bool isLoggedIn = !string.IsNullOrEmpty(userId);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">📦 Liste des produits</h1>
        <div>
            @if (isLoggedIn)
            {
                <a asp-action="Create" class="btn btn-success shadow-sm">
                    <i class="bi bi-plus-circle"></i> Créer Nouveau
                </a>
            }
            else
            {
                <a asp-controller="User" asp-action="Login" class="btn btn-primary shadow-sm">Connexion</a>
                <a asp-controller="User" asp-action="Register" class="btn btn-outline-primary shadow-sm ms-2">Inscription</a>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Name)</th>
                        <th>@Html.DisplayNameFor(model => model.Description)</th>
                        <th class="text-center">@Html.DisplayNameFor(model => model.CurrentPrice)</th>
                        <th class="text-center">@Html.DisplayNameFor(model => model.Stock)</th>
                        <th class="text-end px-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Name</td>
                            <td class="text-muted text-truncate" style="max-width: 250px;">@item.Description</td>
                            <td class="text-center">@item.CurrentPrice.ToString("C")</td>
                            <td class="text-center">
                                <span class="badge @(item.Stock > 0 ? "bg-info" : "bg-warning") text-dark">
                                    @item.Stock
                                </span>
                            </td>
                            <td class="text-end px-4">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-outline-secondary">Détails</a>

                                    @if (isLoggedIn)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-outline-primary">Modifier</a>

                                        @if (item.EntryCount <= 0)
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-outline-danger">Supprimer</a>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
